<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portfolio - Ahmed Temmouri</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root {
            --primary-color: #0056b3; /* لون أزرق احترافي */
            --bg-color: #f4f7f6;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-color);
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 40px 20px;
            margin: 0;
        }
        .profile-card {
            background: white;
            padding: 30px;
            border-radius: 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            text-align: center;
            width: 100%;
            max-width: 400px;
        }
        .profile-img {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            border: 4px solid var(--primary-color);
            object-fit: cover;
            margin-bottom: 15px;
        }
        h1 { font-size: 24px; color: #333; margin-bottom: 5px; }
        p { color: #666; font-size: 16px; margin-bottom: 25px; }
        
        .btn {
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: white;
            color: var(--primary-color);
            border: 2px solid var(--primary-color);
            padding: 15px;
            margin-bottom: 15px;
            border-radius: 12px;
            text-decoration: none;
            font-weight: bold;
            transition: all 0.3s ease;
        }
        .btn:hover {
            background-color: var(--primary-color);
            color: white;
            transform: translateY(-3px);
        }
        .btn i { margin-right: 10px; font-size: 20px; }
        
        .video-container {
            width: 100%;
            max-width: 400px;
            margin-bottom: 20px;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }
    </style>
</head>
<body>

    <div class="profile-card">
        <img src="YOUR_IMAGE_URL" alt="Ahmed Temmouri" class="profile-img">
        <h1>Ahmed Temmouri</h1>
        <p>Bewerbung als Pflegefachmann</p>

        <div class="video-container">
            <video width="100%" controls>
                <source src="YOUR_VIDEO_LINK_HERE" type="video/mp4">
                Ihr Browser unterstützt das Video-Tag nicht.
            </video>
        </div>

        <a href="LINK_TO_LEBENSLAUF" class="btn"><i class="fas fa-file-pdf"></i> Lebenslauf (PDF)</a>
        <a href="LINK_TO_B2" class="btn"><i class="fas fa-language"></i> B2 Zertifikat</a>
        <a href="LINK_TO_MASTER" class="btn"><i class="fas fa-graduation-cap"></i> Master-Abschluss</a>
        <a href="LINK_TO_PASSPORT" class="btn"><i class="fas fa-id-card"></i> EU-Reisepass (FR)</a>
        <a href="mailto:YOUR_EMAIL" class="btn"><i class="fas fa-envelope"></i> Kontaktieren</a>
    </div>

</body>
</html>

